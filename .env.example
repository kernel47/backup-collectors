# Backup Hub (default destination for the Pamela scope)
BACKUP_HUB_URL=https://backup-hub.example.test/api/collections
BACKUP_HUB_TOKEN=

# Logstash (default destination for the Logstash scope)
LOGSTASH_URL=https://logstash.example.test:8080/collections
LOGSTASH_TOKEN=

# Referential (default destination for the Baseline scope)
REFERENTIAL_URL=https://referential.example.test/api/baselines
REFERENTIAL_ASSET_URL=https://referential.example.test/api/assets/{hostname}
REFERENTIAL_TOKEN=

# Local file output and application logging
BACKUP_COLLECTOR_OUTPUT_DIR=/var/lib/backup-collector/outbox
BACKUP_COLLECTOR_LOG_LEVEL=WARNING
